{
  "productName": "Vida AI",
  "version": "0.1.0",
  "identifier": "ai.vida.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3333",
    "beforeDevCommand": "npm run dev -- --port 3333",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Vida AI",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
